# Desarrollo local — Docker Compose (docker-compose.yml)
# Crear archivo activo:  make env-local   →  .env
# Levantar stack:        make up

# --- PostgreSQL ---
POSTGRES_USER=tys
POSTGRES_PASSWORD=tys_dev
POSTGRES_DB=tys_dev
POSTGRES_PORT=5432

# Solo para Alembic / backend fuera de Docker (host → localhost)
DATABASE_URL=postgresql+asyncpg://tys:tys_dev@localhost:5432/tys_dev

# --- Backend ---
JWT_SECRET=dev-secret-cambia-en-produccion
ENV=development_local
FRONTEND_URL=http://localhost:3000
TYS_FEE_PERCENT=5

# --- Frontend (URL que usa el navegador; no uses hostname Docker interno) ---
VITE_BACKEND_URL=http://localhost:8000

# --- Stripe (opcional en local) ---
STRIPE_API_KEY=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_WEBHOOK_SECRET=

# --- Email / Resend (opcional en local) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@ticketyourself.com

# --- Super admin (seed al arrancar) ---
ADMIN_EMAIL=admin@ticketyourself.com
ADMIN_PASSWORD=Admin123!
