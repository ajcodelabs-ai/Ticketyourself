# Backend sin Docker — desarrollo local
# Crear archivo activo:  make env-backend-local   →  backend/.env
# Requiere PostgreSQL en localhost (make up solo postgres, o instalación nativa)

DATABASE_URL=postgresql+asyncpg://tys:tys_dev@localhost:5432/tys_dev

JWT_SECRET=dev-secret-cambia-en-produccion
ENV=development_local
FRONTEND_URL=http://localhost:3000
PUBLIC_DOMAIN=localhost
TYS_FEE_PERCENT=5

STRIPE_API_KEY=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_WEBHOOK_SECRET=

RESEND_API_KEY=
EMAIL_FROM=noreply@ticketyourself.com

ADMIN_EMAIL=admin@ticketyourself.com
ADMIN_PASSWORD=Admin123!
