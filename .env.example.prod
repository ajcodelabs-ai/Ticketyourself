# Producción — Docker Compose (docker-compose.prod.yml)
# Crear archivo activo:  make env-prod   →  .env.prod
# Levantar stack:      make prod-up
#
# IMPORTANTE: no commitees .env.prod. Genera secretos fuertes antes de desplegar.

# --- PostgreSQL ---
POSTGRES_USER=tys
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
POSTGRES_DB=tys_prod

# --- Backend ---
JWT_SECRET=GENERA_CON_openssl_rand_hex_32
ENV=production
FRONTEND_URL=https://app.tudominio.com
PUBLIC_DOMAIN=tudominio.com
TYS_FEE_PERCENT=5

# --- Frontend (URL pública del API; se bakea en el build nginx) ---
VITE_BACKEND_URL=https://api.tudominio.com
VITE_PUBLIC_DOMAIN=tudominio.com

# --- Stripe (requerido en producción) ---
STRIPE_API_KEY=sk_live_...
STRIPE_API_BASE=https://api.stripe.com
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email / Resend ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@ticketyourself.com

# --- Super admin (cambia la contraseña tras el primer deploy) ---
ADMIN_EMAIL=admin@ticketyourself.com
ADMIN_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
